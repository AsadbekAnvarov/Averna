// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  PARENT
  ADMIN
}

enum HomeworkStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
}

enum IELTSModule {
  WRITING
  READING
  LISTENING
  SPEAKING
}

enum AchievementType {
  HOMEWORK_MASTER
  SPEAKING_CHAMPION
  READING_EXPERT
  WRITING_GURU
  LISTENING_MASTER
  TOP_PERFORMER
  STREAK_WARRIOR
  EARLY_BIRD
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          UserRole  @default(STUDENT)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  student       Student?
  teacher       Teacher?
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Student {
  id                String   @id @default(cuid())
  userId            String   @unique
  groupId           String?
  personalGoal      String?
  level             String?  // CEFR/IELTS level, set during enrollment
  phone             String?
  nativeLanguage    String?
  targetBand        String?
  bio               String?
  enrolledAt        DateTime?
  blacklisted       Boolean  @default(false)
  blacklistReason   String?
  totalPoints       Int      @default(0)
  globalRank        Int      @default(0)
  groupRank         Int      @default(0)
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  lastActiveDate    DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  group             Group?               @relation(fields: [groupId], references: [id])
  homeworkSubmissions HomeworkSubmission[]
  ieltsTests        IELTSTest[]
  achievements      StudentAchievement[]
  speakingSessions  SpeakingSession[]
  activityLogs      ActivityLog[]
  parentLinks       ParentStudentLink[]
  tutorBookings     TutorSlot[]
  attendances       Attendance[]
  grades            Grade[]
  redemptions       RewardRedemption[]

  @@index([groupId])
  @@index([totalPoints])
  @@map("students")
}

model Teacher {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  specialty       String?
  isSecondTeacher Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups            Group[]
  homework          Homework[]
  homeworkGrades    HomeworkSubmission[]
  speakingSessions  SpeakingSession[]
  tutorSlots        TutorSlot[]
  attendanceRecords Attendance[]
  grades            Grade[]

  @@map("teachers")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  teacherId   String
  description String?
  level       String?
  schedule    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  students    Student[]
  homework    Homework[]
  attendances Attendance[]

  @@index([teacherId])
  @@map("groups")
}

model Homework {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  teacherId   String
  groupId     String
  dueDate     DateTime
  points      Int            @default(10)
  difficulty  Int            @default(1)
  module      IELTSModule
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  teacher     Teacher              @relation(fields: [teacherId], references: [id])
  group       Group                @relation(fields: [groupId], references: [id])
  submissions HomeworkSubmission[]

  @@index([groupId])
  @@index([teacherId])
  @@index([dueDate])
  @@map("homework")
}

model HomeworkSubmission {
  id           String         @id @default(cuid())
  studentId    String
  homeworkId   String
  content      String         @db.Text
  status       HomeworkStatus @default(SUBMITTED)
  position     Int?
  pointsAwarded Int           @default(0)
  feedback     String?        @db.Text
  gradedBy     String?
  submittedAt  DateTime       @default(now())
  gradedAt     DateTime?

  // Relations
  student  Student  @relation(fields: [studentId], references: [id])
  homework Homework @relation(fields: [homeworkId], references: [id])
  teacher  Teacher? @relation(fields: [gradedBy], references: [id])

  @@unique([studentId, homeworkId])
  @@index([homeworkId])
  @@index([status])
  @@map("homework_submissions")
}

model IELTSTest {
  id              String      @id @default(cuid())
  studentId       String
  module          IELTSModule
  score           Float
  answers         Json
  aiAnalysis      Json?
  timeSpent       Int // in seconds
  completedAt     DateTime    @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([module])
  @@map("ielts_tests")
}

model Achievement {
  id          String            @id @default(cuid())
  type        AchievementType   @unique
  name        String
  description String
  icon        String
  points      Int               @default(0)
  createdAt   DateTime          @default(now())

  // Relations
  students StudentAchievement[]

  @@map("achievements")
}

model StudentAchievement {
  id            String   @id @default(cuid())
  studentId     String
  achievementId String
  unlockedAt    DateTime @default(now())

  // Relations
  student     Student     @relation(fields: [studentId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([studentId, achievementId])
  @@index([studentId])
  @@map("student_achievements")
}

model SpeakingSession {
  id          String   @id @default(cuid())
  studentId   String
  teacherId   String?
  duration    Int // in minutes
  points      Int      @default(0)
  feedback    String?  @db.Text
  rating      Int? // 1-5 stars from teacher
  date        DateTime @default(now())

  // Relations
  student Student  @relation(fields: [studentId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([date])
  @@map("speaking_sessions")
}

model ActivityLog {
  id        String   @id @default(cuid())
  studentId String
  action    String
  details   Json?
  points    Int      @default(0)
  createdAt DateTime @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([createdAt])
  @@map("activity_logs")
}

model ParentStudentLink {
  id         String   @id @default(cuid())
  parentName String
  parentEmail String
  studentId  String
  createdAt  DateTime @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id])

  @@unique([parentEmail, studentId])
  @@index([studentId])
  @@map("parent_student_links")
}

model DailyQuote {
  id        String   @id @default(cuid())
  text      String   @db.Text
  author    String?
  date      DateTime @unique @default(now())
  createdAt DateTime @default(now())

  @@index([date])
  @@map("daily_quotes")
}

model TutorSlot {
  id        String   @id @default(cuid())
  teacherId String
  day       String // e.g. "Monday"
  startTime String // e.g. "18:00"
  endTime   String // e.g. "19:00"
  topic     String?
  studentId String?
  createdAt DateTime @default(now())

  // Relations
  teacher Teacher  @relation(fields: [teacherId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@index([teacherId])
  @@index([studentId])
  @@map("tutor_slots")
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  groupId   String
  teacherId String?
  date      DateTime @default(now())
  status    String   @default("PRESENT") // PRESENT | ABSENT | LATE | EXCUSED
  note      String?
  createdAt DateTime @default(now())

  // Relations
  student Student  @relation(fields: [studentId], references: [id])
  group   Group    @relation(fields: [groupId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  @@index([groupId, date])
  @@index([studentId])
  @@map("attendance")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("system") // homework | grade | booking | message | system
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model Grade {
  id        String   @id @default(cuid())
  studentId String
  teacherId String?
  groupId   String?
  title     String
  score     Float
  maxScore  Float    @default(100)
  comment   String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  student Student  @relation(fields: [studentId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@map("grades")
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  cost        Int
  icon        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  redemptions RewardRedemption[]

  @@map("rewards")
}

model RewardRedemption {
  id        String   @id @default(cuid())
  studentId String
  rewardId  String
  cost      Int
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  reward  Reward  @relation(fields: [rewardId], references: [id])

  @@index([studentId])
  @@map("reward_redemptions")
}

model SpeakingQueue {
  id          String   @id @default(cuid())
  studentId   String   @unique
  studentName String
  roomId      String?
  topic       String?
  createdAt   DateTime @default(now())

  @@map("speaking_queue")
}

model SpeakingRoom {
  id           String    @id @default(cuid())
  topic        String
  studentAId   String
  studentAName String
  studentBId   String
  studentBName String
  status       String    @default("ACTIVE") // ACTIVE | ENDED
  createdAt    DateTime  @default(now())
  endedAt      DateTime?

  @@map("speaking_rooms")
}

model SpeakingMessage {
  id         String   @id @default(cuid())
  roomId     String
  senderId   String
  senderName String
  content    String
  createdAt  DateTime @default(now())

  @@index([roomId])
  @@map("speaking_messages")
}
