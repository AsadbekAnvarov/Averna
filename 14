"use client";

import { useState } from "react";
import Link from "next/link";

const personalGoals = [
  "IELTS 7.5+",
  "Study Abroad",
  "Work Opportunities",
  "Immigration",
  "Personal Development",
];

export default function ProfilePage() {
  const [profile, setProfile] = useState({
    name: "John Smith",
    email: "student1@averna.com",
    personalGoal: "IELTS 7.5+",
    totalPoints: 350,
    currentStreak: 7,
  });
  const [isEditing, setIsEditing] = useState(false);
  const [isSaving, setIsSaving] = useState(false);

  const handleSave = async () => {
    setIsSaving(true);
    // Симуляция сохранения
    setTimeout(() => {
      setIsSaving(false);
      setIsEditing(false);
      alert("Profile updated successfully!");
    }, 1000);
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-green-900 to-green-600">
      <div className="container mx-auto px-4 py-8 max-w-4xl">
        <Link href="/dashboard" className="text-green-200 hover:text-white text-sm mb-4 inline-block">
          ← Back to Dashboard
        </Link>

        <h1 className="text-4xl font-bold text-white mb-8 flex items-center gap-3">
          <span className="text-4xl">👤</span>
          My Profile
        </h1>

        {/* Stats Cards */}
        <div className="grid md:grid-cols-3 gap-6 mb-8">
          <div className="bg-white/10 backdrop-blur-lg rounded-lg p-6 border border-white/20">
            <div className="text-green-200 text-sm font-semibold mb-2">Total Points</div>
            <div className="text-3xl font-bold text-white">{profile.totalPoints}</div>
          </div>

          <div className="bg-white/10 backdrop-blur-lg rounded-lg p-6 border border-white/20">
            <div className="text-orange-200 text-sm font-semibold mb-2">Current Streak</div>
            <div className="text-3xl font-bold text-orange-400">{profile.currentStreak}</div>
          </div>

          <div className="bg-white/10 backdrop-blur-lg rounded-lg p-6 border border-white/20">
            <div className="text-blue-200 text-sm font-semibold mb-2">Account Status</div>
            <div className="text-lg font-bold text-green-400">Active</div>
          </div>
        </div>

        {/* Profile Form */}
        <div className="bg-white/10 backdrop-blur-lg rounded-lg p-8 border border-white/20">
          <div className="flex justify-between items-center mb-6">
            <h2 className="text-2xl font-bold text-white">Profile Information</h2>
            {!isEditing && (
              <button
                onClick={() => setIsEditing(true)}
                className="bg-green-400 text-black px-4 py-2 rounded-lg font-semibold hover:bg-green-300"
              >
                Edit Profile
              </button>
            )}
          </div>

          <div className="space-y-4">
            <div>
              <label className="block text-white text-sm font-semibold mb-2">
                Full Name
              </label>
              <input
                type="text"
                value={profile.name}
                onChange={(e) => setProfile({ ...profile, name: e.target.value })}
                disabled={!isEditing}
                className="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/30 text-white placeholder-gray-300 focus:outline-none focus:border-green-400 disabled:opacity-60"
              />
            </div>

            <div>
              <label className="block text-white text-sm font-semibold mb-2">
                Email (Read-only)
              </label>
              <input
                type="email"
                value={profile.email}
                disabled
                className="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/30 text-gray-300 opacity-60"
              />
              <p className="text-green-200 text-xs mt-1">
                Contact admin to change your email address
              </p>
            </div>

            <div>
              <label className="block text-white text-sm font-semibold mb-2">
                Learning Goal
              </label>
              <select
                value={profile.personalGoal}
                onChange={(e) => setProfile({ ...profile, personalGoal: e.target.value })}
                disabled={!isEditing}
                className="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/30 text-white focus:outline-none focus:border-green-400 disabled:opacity-60"
              >
                {personalGoals.map((goal) => (
                  <option key={goal} value={goal} className="bg-green-800">
                    {goal}
                  </option>
                ))}
              </select>
              <p className="text-green-200 text-xs mt-1">
                This helps us personalize your learning experience
              </p>
            </div>

            {isEditing && (
              <div className="flex gap-4 pt-4">
                <button
                  onClick={handleSave}
                  disabled={isSaving}
                  className="flex-1 bg-green-400 text-black font-bold py-3 rounded-lg hover:bg-green-300 disabled:opacity-50"
                >
                  {isSaving ? "Saving..." : "Save Changes"}
                </button>
                <button
                  onClick={() => setIsEditing(false)}
                  disabled={isSaving}
                  className="flex-1 bg-white/20 text-white font-bold py-3 rounded-lg hover:bg-white/30"
                >
                  Cancel
                </button>
              </div>
            )}
          </div>
        </div>

        {/* Additional Info */}
        <div className="bg-white/10 backdrop-blur-lg rounded-lg p-6 border border-white/20 mt-6">
          <h3 className="text-xl font-bold text-white mb-4">Account Activity</h3>
          <div className="space-y-2 text-sm">
            <div className="flex justify-between">
              <span className="text-green-200">Member since:</span>
              <span className="text-white font-semibold">January 2024</span>
            </div>
            <div className="flex justify-between">
              <span className="text-green-200">Tests completed:</span>
              <span className="text-white font-semibold">25</span>
            </div>
            <div className="flex justify-between">
              <span className="text-green-200">Homework submitted:</span>
              <span className="text-white font-semibold">15</span>
            </div>
            <div className="flex justify-between">
              <span className="text-green-200">Speaking sessions:</span>
              <span className="text-white font-semibold">8</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
